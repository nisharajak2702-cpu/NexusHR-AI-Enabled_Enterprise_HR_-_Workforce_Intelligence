# Copy this file to .env and fill in your real values before starting the containers.
# DO NOT commit .env with secrets to source control.

# When you want the backend to connect to your host PostgreSQL 18 server,
# use host.docker.internal from inside Docker.
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/nexushr
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=80160

# The database name used by the backend.
POSTGRES_DB=nexushr

# JWT secret used by backend
JWT_SECRET=YOUR_SUPER_SECRET_KEY_12345678901234567890

# Ports
SPRING_PORT=8080
REACT_PORT=3000
